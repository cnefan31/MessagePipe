```gitignore
# Build artifacts
bin/
obj/
out/
dist/
build/
*.dll
*.exe
*.pdb
*.so
*.dylib
*.nupkg
*.snupkg

# Dependencies
packages/
node_modules/
vendor/

# Logs
*.log
**/logs/

# Environment
.env
.env.local
.env.*
!.env.example

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
htmlcov/
*.coverage
```